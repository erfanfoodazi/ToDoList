@model GroupTodosViewModel
@{
    ViewData["Title"] = $"Group Tasks - {Model.GroupTitle}";
    Layout = "_Layout";
}

<style>
    /* Notion Style - No custom CSS except colors */
    .notion-table {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, "Apple Color Emoji", Arial, sans-serif;
        font-size: 14px;
        border-collapse: collapse;
        width: 100%;
    }

        .notion-table th {
            background-color: #f7f6f3;
            border-bottom: 1px solid #e5e5e5;
            padding: 12px 8px;
            font-weight: 500;
            cursor: help;
        }

        .notion-table td {
            border-bottom: 1px solid #e5e5e5;
            padding: 10px 8px;
            transition: background-color 0.15s ease;
        }

    .notion-checkbox {
        width: 22px;
        height: 22px;
        border-radius: 4px;
        border: 2px solid #dadada;
        background: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.1s ease;
    }

        .notion-checkbox:hover {
            border-color: #9b9b9b;
            background-color: #f5f5f5;
        }

        .notion-checkbox.checked {
            background-color: #2eaadc;
            border-color: #2eaadc;
            color: white;
        }

    .row-hover:hover {
        background-color: #f7f6f3 !important;
    }

    .priority-high {
        background-color: #ffe9e9;
    }

    .priority-medium {
        background-color: #fff4e5;
    }

    .priority-low {
        background-color: #e8f5e9;
    }

    .completed-row {
        background-color: #f8f8f8;
        color: #9b9b9b;
    }

    .completed-cell {
        text-decoration: line-through;
        color: #9b9b9b;
    }

    .task-header {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .task-title {
        font-weight: 500;
        font-size: 14px;
    }

    .task-priority {
        font-size: 11px;
        color: #6b6b6b;
    }

    .date-cell {
        color: #37352f;
        font-weight: 500;
        font-size: 13px;
    }

    .tooltip-custom {
        visibility: hidden;
        background-color: #1e1e1e;
        color: white;
        text-align: center;
        border-radius: 6px;
        padding: 6px 12px;
        position: fixed; /* تغییر از absolute به fixed */
        z-index: 9999; /* افزایش z-index برای نمایش بالای همه چیز */
        white-space: nowrap;
        font-size: 12px;
        pointer-events: none; /* جلوگیری از تداخل موس */
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }

    .th-container {
        position: relative;
        display: inline-block;
        width: 100%;
    }

        .th-container:hover .tooltip-custom {
            visibility: visible;
        }
</style>

<div class="container-fluid px-4 py-3">
    <!-- Header - Notion Style -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2" style="border-bottom: 1px solid #e5e5e5;">
        <div>
            <h1 class="h3" style="font-weight: 600; color: #37352f;">
                <i class="fas fa-folder-open me-2" style="color: #2eaadc;"></i> @Model.GroupTitle
            </h1>
            <div class="mt-2" style="font-size: 13px; color: #6b6b6b;">
                <span class="me-3">
                    <i class="fas fa-sync-alt me-1" style="font-size: 11px;"></i> @Model.RepetitionType
                </span>
                <span>
                    <i class="fas fa-calendar-alt me-1" style="font-size: 11px;"></i> Created @Model.CreatedAt
                </span>
            </div>
        </div>

        <div class="d-flex gap-1">
            <a asp-action="AddTodoItem" asp-route-groupId="@Model.GroupId" class="btn btn-outline-primary btn-sm"
               style="border-radius: 4px; padding: 6px 12px; font-size: 13px;">
                <i class="fas fa-plus me-1"></i> Add task
            </a>

            <a asp-controller="GroupItems" asp-action="Index" class="btn btn-outline-secondary btn-sm"
               style="border-radius: 4px; padding: 6px 12px; font-size: 13px;">
                <i class="fas fa-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>
</div>
<!-- Notion Style Table -->
<div class="table-responsive">
    <table class="notion-table">
        <thead>
            <tr>
                <th style="width: 110px;">Date</th>
                @foreach (var task in Model.TasksWithPriority)
                {
                    <th>
                        <div class="th-container">
                            <div class="task-header">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="task-title">@task.Title</span>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li>
                                                <a class="dropdown-item" href="#" onclick="editTask(@task.Id, '@task.Title', '@task.Priority', '@task.Description', @task.GroupId)">
                                                    <i class="fas fa-edit me-2"></i> Edit
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item text-danger" href="#" onclick="deleteTask(@task.Id, '@task.Title')">
                                                    <i class="fas fa-trash me-2"></i> Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                                <span class="task-priority">
                                    @{
                                        var priorityIcon = task.Priority switch
                                        {
                                            "High" => "🔴",
                                            "Medium" => "🟡",
                                            "Low" => "🟢",
                                            _ => "⚪"
                                        };
                                    }
                                    @priorityIcon @task.Priority
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(task.Description))
                            {
                                <div class="tooltip-custom">@task.Description</div>
                            }
                        </div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var repetition in Model.Repetitions.OrderByDescending(r => r.RepetitionDate))
            {
                <tr class="row-hover">
                    <td class="date-cell">
                        <i class="far fa-calendar-alt me-2" style="color: #9b9b9b; font-size: 12px;"></i>
                        @repetition.RepetitionDate
                    </td>

                    @foreach (var task in Model.TasksWithPriority)
                    {
                        var todo = repetition.TodoItems.FirstOrDefault(t => t.Title == task.Title);
                        var isCompleted = todo?.IsComplete ?? false;
                        var priority = todo?.Priority ?? task.Priority;

                        var priorityClass = priority == "High" ? "priority-high" :
                        priority == "Medium" ? "priority-medium" :
                        priority == "Low" ? "priority-low" : "";

                        <td class="@(isCompleted ? "completed-cell" : "") @priorityClass"
                            style="cursor: pointer;">
                            @if (todo != null)
                            {
                                <form asp-controller="TodoItems" asp-action="ToggleComplete" method="post" style="margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="taskId" value="@todo.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                    <button type="submit"
                                            style="background: none; border: none; padding: 0; margin: 0; cursor: pointer; width: 100%; text-align: left;">
                                        <div class="notion-checkbox @(isCompleted ? "checked" : "")">
                                            @if (isCompleted)
                                            {
                                                <i class="fas fa-check" style="font-size: 11px;"></i>
                                            }
                                        </div>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="notion-checkbox" style="opacity: 0.3;"></div>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Empty State -->
@if (!Model.Repetitions.Any())
{
    <div class="text-center py-5 my-5">
        <i class="far fa-calendar-times" style="font-size: 48px; color: #9b9b9b;"></i>
        <p class="mt-3" style="color: #6b6b6b;">No tasks yet. Create a repetition to get started.</p>
    </div>
}

<!-- Footer Stats - Notion Style -->
<div class="mt-4 pt-3 d-flex justify-content-between align-items-center" style="border-top: 1px solid #e5e5e5; font-size: 12px; color: #6b6b6b;">
    <div>
        <i class="fas fa-chart-simple me-1"></i>
        @{
            var total = Model.Repetitions.SelectMany(r => r.TodoItems).Count();
            var completed = Model.Repetitions.SelectMany(r => r.TodoItems).Count(t => t.IsComplete);
            var percent = total > 0 ? (completed * 100 / total) : 0;
        }
        @completed / @total tasks completed · @percent% done
    </div>
    <div>
        <i class="fas fa-info-circle me-1"></i> Hover on task names for details
    </div>
</div>

<div class="modal fade" id="editTaskModal" tabindex="-1" aria-labelledby="editTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="editTaskModalLabel">
                    <i class="fas fa-edit me-2"></i>Edit Task
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editTaskForm" asp-controller="TodoItems" asp-action="EditTask" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TaskId" id="editTaskId" />
                <input type="hidden" name="GroupId" id="editGroupId" />

                <div class="modal-body">
                    <!-- Title -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Task Title</label>
                        <input type="text" name="Title" id="editTaskTitle" class="form-control" required />
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description (Optional)</label>
                        <textarea name="Description" id="editTaskDescription" class="form-control" rows="3"></textarea>
                    </div>

                    <!-- Priority -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Priority</label>
                        <select name="Priority" id="editTaskPriority" class="form-select">
                            <option value="0">🟢 Low Priority</option>
                            <option value="1">🟡 Medium Priority</option>
                            <option value="2">🔴 High Priority</option>
                            <option value="3">⚫ Critical Priority</option>
                        </select>
                    </div>

                    <!-- Preview -->
                    <div class="mb-3 p-3" style="background-color: #f7f6f3; border-radius: 8px;">
                        <div class="d-flex align-items-center gap-2">
                            <div class="notion-checkbox" style="opacity: 0.4;"></div>
                            <span id="previewTaskTitle" style="color: #9b9b9b;">Preview</span>
                        </div>
                        <div class="mt-2">
                            <span id="previewTaskPriority" class="badge bg-secondary">Priority</span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add hover effect for rows
        document.querySelectorAll('.notion-table tbody tr').forEach(row => {
            row.addEventListener('mouseenter', () => {
                row.style.backgroundColor = '#f7f6f3';
            });
            row.addEventListener('mouseleave', () => {
                row.style.backgroundColor = '';
            });
        });

        // Tooltip positioning with fixed
        document.querySelectorAll('.th-container').forEach(container => {
            const tooltip = container.querySelector('.tooltip-custom');
            if (!tooltip) return;

            container.addEventListener('mouseenter', (e) => {
                const rect = container.getBoundingClientRect();
                tooltip.style.left = rect.left + (rect.width / 2) + 'px';
                tooltip.style.top = (rect.top - 30) + 'px';
                tooltip.style.transform = 'translateX(-50%)';
            });
        });

        function editTask(id, title, priority, description, groupId) {
            document.getElementById('editTaskId').value = id;
            document.getElementById('editTaskTitle').value = title;
            document.getElementById('editTaskDescription').value = description || '';
            document.getElementById('editGroupId').value = groupId;

            var priorityValue = 1; 
            switch(priority) {
                case 'Low':
                    priorityValue = 0;
                    break;
                case 'Medium':
                    priorityValue = 1;
                    break;
                case 'High':
                    priorityValue = 2;
                    break;
                case 'Critical':
                    priorityValue = 3;
                    break;
            }
            document.getElementById('editTaskPriority').value = priorityValue;

            updatePreview(title, priorityValue);

            var modal = new bootstrap.Modal(document.getElementById('editTaskModal'));
            modal.show();
        }

        function deleteTask(taskId, title) {
            if (confirm(`Are you sure you want to delete task "${title}"?`)) {
                fetch(`/TodoItems/DeleteTask/${taskId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                }).then(response => {
                    if (response.ok) {
                        window.location.reload();
                    } else {
                        alert('Failed to delete task');
                    }
                });
            }
        }

        function updatePreview(title, priorityValue) {
            const previewTitle = document.getElementById('previewTaskTitle');
            const previewPriority = document.getElementById('previewTaskPriority');

            if (title && title.trim()) {
                previewTitle.textContent = title;
                previewTitle.style.color = '#37352f';
            } else {
                previewTitle.textContent = 'Preview';
                previewTitle.style.color = '#9b9b9b';
            }

            let priorityText = '';
            let priorityClass = '';
            switch(parseInt(priorityValue)) {
                case 0:
                    priorityText = '🟢 Low Priority';
                    priorityClass = 'success';
                    break;
                case 1:
                    priorityText = '🟡 Medium Priority';
                    priorityClass = 'warning';
                    break;
                case 2:
                    priorityText = '🔴 High Priority';
                    priorityClass = 'danger';
                    break;
                case 3:
                    priorityText = '⚫ Critical Priority';
                    priorityClass = 'dark';
                    break;
                default:
                    priorityText = 'Priority';
                    priorityClass = 'secondary';
            }
            previewPriority.textContent = priorityText;
            previewPriority.className = `badge bg-${priorityClass}`;
        }

        // Event listeners for live preview
        document.addEventListener('DOMContentLoaded', function() {
            const titleInput = document.getElementById('editTaskTitle');
            const prioritySelect = document.getElementById('editTaskPriority');

            if (titleInput) {
                titleInput.addEventListener('input', function() {
                    updatePreview(this.value, prioritySelect.value);
                });
            }

            if (prioritySelect) {
                prioritySelect.addEventListener('change', function() {
                    updatePreview(titleInput ? titleInput.value : '', this.value);
                });
            }
        });
    </script>
}